# Required for enabled providers
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
DEEPGRAM_API_KEY=

# Pipeline behavior
TRANSCRIBE_PROVIDERS=openai,deepgram
LANGUAGE_HINT=en
SILENCE_GAP_SECONDS=90
MAX_RETRIES=3
LOG_LEVEL=INFO

# Models
TRANSCRIBE_OPENAI_MODEL=gpt-4o-transcribe
TRANSCRIBE_DEEPGRAM_MODEL=nova-3
TRANSCRIBE_CHUNK_SECONDS=540
TRANSCRIBE_CHUNK_OVERLAP_SECONDS=5
RECONCILER_MODEL=gpt-5
RECONCILER_PROVIDER=openai
POLISH_PROVIDER=openai
POLISH_MODEL=gpt-5
POLISH_LONG_SILENCE_SECONDS=90

# Paths
DATA_ROOT=./data
INBOX_DIR=./data/inbox
OUTPUT_ROOT=./outputs
LOGS_DIR=./logs
STATE_DB_PATH=./data/state/pipeline.db
PIPELINE_VERSION=0.1.0

# Export
EXPORT_PUBLISH_DIR=

# Web interface (scripts/serve_web.py)
WEB_PASSWORD=
WEB_SECRET_KEY=
WEB_HOST=127.0.0.1
WEB_PORT=8080
WEB_MAX_UPLOAD_MB=512
WEB_SESSION_COOKIE_SECURE=true
