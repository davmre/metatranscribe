# Required for enabled providers
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
DEEPGRAM_API_KEY=

# Pipeline behavior
TRANSCRIBE_PROVIDERS=openai,deepgram
LANGUAGE_HINT=en
SILENCE_GAP_SECONDS=90
MAX_RETRIES=3
LOG_LEVEL=INFO
OUTPUT_STYLE=paragraph
PARAGRAPH_GAP_SECONDS=20
PARAGRAPH_MAX_CHARS=600

# Models
TRANSCRIBE_OPENAI_MODEL=gpt-4o-transcribe
TRANSCRIBE_DEEPGRAM_MODEL=nova-3
TRANSCRIBE_CHUNK_SECONDS=540
USE_TRANSCRIBE_CHUNKS_FOR_RECONCILE=true
RECONCILER_MODEL=gpt-5
RECONCILER_PROVIDER=openai
RECONCILE_CHUNK_SECONDS=300
RECONCILE_CHUNK_OVERLAP_SECONDS=20
ENABLE_POLISH_PASS=true
POLISH_PROVIDER=openai
POLISH_MODEL=gpt-5
POLISH_LONG_SILENCE_SECONDS=90

# Paths
DATA_ROOT=./data
INBOX_DIR=./data/inbox
OUTPUT_ROOT=./outputs
LOGS_DIR=./logs
STATE_DB_PATH=./data/state/pipeline.db
PIPELINE_VERSION=0.1.0
